# HydroPredict Backend Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
ENVIRONMENT=development

# Model Configuration
MODEL_CHECKPOINT_PATH=../HydroPredict-model/checkpoints/version_010_20260216_104439/hydropredict-epoch=epoch=08-val_loss=val_loss=1.6287.ckpt
MODEL_CONFIG_PATH=../HydroPredict-model/configs/model_config.json
HISTORICAL_DATA_PATH=../HydroPredict-model/data/input/hourly-data-2024-2025.csv

# Weatherbit API
WEATHERBIT_CONFIG_PATH=../HydroPredict-model/configs/weatherbit.json
WEATHERBIT_API_KEY=your_api_key_here

# Database (Optional - for production)
DATABASE_URL=postgresql://user:password@localhost:5432/hydropredict

# Redis (Optional - for production caching)
REDIS_URL=redis://localhost:6379/0

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:8080"]

# Scheduler Settings
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=3600

# Security
SECRET_KEY=your-secret-key-change-in-production

