# HydroPredict Backend Configuration

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
ENVIRONMENT=development

# Model Configuration
MODEL_CHECKPOINT_PATH=checkpoints/final_model.ckpt
MODEL_CONFIG_PATH=configs/model_config.json
HISTORICAL_DATA_PATH=data/input/hourly-data-2024-2025.csv

# Weatherbit API
WEATHERBIT_CONFIG_PATH=configs/weatherbit.json
WEATHERBIT_API_KEY=your_api_key_here

# Database (Optional - for production)
DATABASE_URL=postgresql://user:password@localhost:5432/hydropredict

# Redis (Optional - for production caching)
REDIS_URL=redis://localhost:6379/0

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:8080"]

# Scheduler Settings
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=3600

# Security
SECRET_KEY=your-secret-key-change-in-production

